# =============================================================================
# Clara .NET Gateway — Environment Variables
# =============================================================================
# Copy to .env and fill in your values.
# These override appsettings.json values. Use __ (double underscore) for
# nested config sections, e.g. Clara__Llm__Provider maps to Clara:Llm:Provider.

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------
OPENAI_API_KEY=                        # Always needed (embeddings)
ANTHROPIC_API_KEY=                     # Required if using Anthropic provider

# -----------------------------------------------------------------------------
# LLM Provider
# -----------------------------------------------------------------------------
Clara__Llm__Provider=anthropic         # anthropic | openrouter | openai | nanogpt

# Provider API keys (set the one matching your provider)
# Clara__Llm__OpenRouter__ApiKey=
# Clara__Llm__OpenAi__ApiKey=
# Clara__Llm__NanoGpt__ApiKey=

# Model tiers (optional — defaults in appsettings.json)
# Clara__Llm__Anthropic__Models__High=claude-opus-4-5
# Clara__Llm__Anthropic__Models__Mid=claude-sonnet-4-5
# Clara__Llm__Anthropic__Models__Low=claude-haiku-4-5

# Auto tier selection (classify message complexity -> pick tier)
# Clara__Llm__AutoTierSelection=true
# Clara__Llm__DefaultTier=mid

# -----------------------------------------------------------------------------
# Gateway
# -----------------------------------------------------------------------------
Clara__Gateway__Host=127.0.0.1
Clara__Gateway__Port=18789
# Clara__Gateway__Secret=              # Optional auth secret for adapter connections
# Clara__Gateway__MaxToolRounds=10
# Clara__Gateway__MaxToolResultChars=50000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Default: SQLite at data/clara.db
# For PostgreSQL with pgvector:
# ConnectionStrings__Clara=Host=localhost;Database=clara;Username=clara;Password=clara

# -----------------------------------------------------------------------------
# Memory
# -----------------------------------------------------------------------------
# Clara__Memory__EmbeddingModel=text-embedding-3-small
# Clara__Memory__SearchLimit=10
# Clara__Memory__ExtractionModel=gpt-4o-mini
# Clara__Memory__SessionIdleMinutes=30

# -----------------------------------------------------------------------------
# Discord Adapter
# -----------------------------------------------------------------------------
# DISCORD_BOT_TOKEN=
# Clara__Discord__AllowedServers__0=   # Server ID allowlist (0-indexed)
# Clara__Discord__MaxImages=1
# Clara__Discord__MaxImageDimension=1568

# -----------------------------------------------------------------------------
# Teams Adapter
# -----------------------------------------------------------------------------
# TEAMS_APP_ID=
# TEAMS_APP_PASSWORD=

# -----------------------------------------------------------------------------
# Tool Integrations
# -----------------------------------------------------------------------------
# GITHUB_TOKEN=
# AZURE_DEVOPS_ORG=
# AZURE_DEVOPS_PAT=
# TAVILY_API_KEY=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=

# -----------------------------------------------------------------------------
# Sandbox (Docker code execution)
# -----------------------------------------------------------------------------
# Clara__Sandbox__Mode=auto            # docker | auto
# Clara__Sandbox__Docker__Image=python:3.12-slim
# Clara__Sandbox__Docker__TimeoutSeconds=900

# -----------------------------------------------------------------------------
# Heartbeat
# -----------------------------------------------------------------------------
# Clara__Heartbeat__Enabled=false
# Clara__Heartbeat__IntervalMinutes=30
# Clara__Heartbeat__ChecklistPath=workspace/heartbeat.md

# -----------------------------------------------------------------------------
# Sub-Agents
# -----------------------------------------------------------------------------
# Clara__SubAgents__MaxPerParent=5
# Clara__SubAgents__DefaultTier=low
# Clara__SubAgents__TimeoutMinutes=10
