# Required
OPENAI_API_KEY=
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Gateway
CLARA_GATEWAY_HOST=127.0.0.1
CLARA_GATEWAY_PORT=18789
CLARA_GATEWAY_API_PORT=18790
# CLARA_GATEWAY_SECRET=

# Database (default: SQLite)
# DATABASE_URL=postgresql://user:pass@localhost:5432/clara

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Rook (memory extraction LLM)
ROOK_PROVIDER=openrouter
ROOK_MODEL=openai/gpt-4o-mini

# Model tiers (optional)
# MODEL_TIER=mid
# ANTHROPIC_MODEL_HIGH=claude-opus-4-5
# ANTHROPIC_MODEL_MID=claude-sonnet-4-5
# ANTHROPIC_MODEL_LOW=claude-haiku-4-5

# CORS
GATEWAY_API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
