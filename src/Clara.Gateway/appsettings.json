{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Clara": "Data Source=data/clara.db"
  },
  "Clara": {
    "Gateway": {
      "Host": "127.0.0.1",
      "Port": 18789,
      "Secret": null,
      "MaxToolRounds": 10,
      "MaxToolResultChars": 50000,
      "CorsOrigins": null
    },
    "Llm": {
      "Provider": "anthropic",
      "DefaultTier": "mid",
      "AutoTierSelection": true,
      "Anthropic": {
        "ApiKey": null,
        "BaseUrl": null,
        "Models": {
          "High": "claude-sonnet-4-20250514",
          "Mid": "claude-sonnet-4-20250514",
          "Low": "claude-haiku-4-20250414"
        }
      },
      "OpenRouter": {
        "ApiKey": null,
        "BaseUrl": "https://openrouter.ai/api/v1",
        "Models": {
          "High": "anthropic/claude-sonnet-4-20250514",
          "Mid": "anthropic/claude-sonnet-4-20250514",
          "Low": "anthropic/claude-haiku-4-20250414"
        }
      },
      "OpenAi": {
        "ApiKey": null,
        "BaseUrl": null,
        "Models": {
          "High": "gpt-4o",
          "Mid": "gpt-4o-mini",
          "Low": "gpt-4o-mini"
        }
      },
      "NanoGpt": {
        "ApiKey": null,
        "BaseUrl": "https://nano-gpt.com/api/v1",
        "Models": {
          "High": null,
          "Mid": null,
          "Low": null
        }
      }
    },
    "Memory": {
      "EmbeddingModel": "text-embedding-3-small",
      "EmbeddingApiKey": null,
      "SearchLimit": 10,
      "ExtractionModel": "gpt-4o-mini",
      "SessionIdleMinutes": 30,
      "EnableGraphMemory": false
    },
    "Tools": {
      "DescriptionTier": "low",
      "DescriptionMaxWords": 20,
      "LoopDetection": {
        "MaxIdenticalCalls": 3,
        "MaxTotalRounds": 10
      },
      "DefaultPolicy": {
        "Allow": ["*"],
        "Deny": []
      },
      "ChannelPolicies": {}
    },
    "Sandbox": {
      "Mode": "auto",
      "Docker": {
        "Image": "python:3.12-slim",
        "TimeoutSeconds": 900,
        "Memory": "512m",
        "Cpu": 1.0
      }
    },
    "Heartbeat": {
      "Enabled": false,
      "IntervalMinutes": 30,
      "ChecklistPath": "workspace/heartbeat.md"
    },
    "SubAgents": {
      "MaxPerParent": 5,
      "DefaultTier": "low",
      "TimeoutMinutes": 10
    },
    "Discord": {
      "BotToken": null,
      "AllowedServers": [],
      "StopPhrases": [],
      "MaxImages": 1,
      "MaxImageDimension": 1568
    }
  },
  "Hooks": {
    "Directory": "hooks/hooks.yaml"
  },
  "Scheduler": {
    "Directory": "scheduler.yaml"
  }
}
